# Keep docker context small and avoid unreadable local cache paths
.gradle-cache/
.gradle-cache
.gradle-cache/**
.git/
node_modules/
__pycache__/
*.pyc
test-results/
test_reports/
frontend/node_modules/
.venv/
.tmp/
artifacts/
atomic-red-team/
atomic-validation-results/
evidence-bundle/
metatron-evidence-package-*/
raw-runs/
tools/**/__pycache__/

# Large archives / binaries (not needed for images)
*.zip
*.tar.gz
*.tgz
*.deb
*.pdf
*.docx

# Evidence is mostly runtime data; keep only Presence UI assets in the build
evidence/**
!evidence/Presence\ UI/**
