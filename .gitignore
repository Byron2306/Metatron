# Packaged repo .gitignore (source-only; no runtime artifacts or secrets)

# Editors / OS
.idea/
.vscode/
.DS_Store
*.swp
*~

# Local agent/tooling state
.claude/
.codex
frontend/.codex
.mcp-debug-tools/

# Node / React
node_modules/
/.pnp
.pnp.js
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/versions/
.yarn/install-state.gz
coverage/
build/
dist/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# Python
__pycache__/
*.py[cod]
venv/
.venv/
.pytest_cache/
.mypy_cache/

# Environment / secrets
.env
.env.*
*.env
*.env.*
.envrc
.gitconfig
*token.json*
*credentials.json*
*key_vault*.json
*keyvault*.json
arda_key_vault.json
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr
wg0.conf

# Logs / debug output
*.log
dump.rdb
*.hprof
.~lock.*
n
build_log.txt
*_build_output.txt

# Large binaries / archives (keep out of GitHub by default)
*.zip
*.tar
*.tar.gz
*.tgz
*.deb
*.dylib
*.pdf
*.docx

# Runtime artifacts / caches / generated data
.cache/
.gradle/
**/.gradle/
.gradle-cache/
.tmp/
artifacts/
atomic-red-team/
atomic-validation-results/
evidence-bundle/
raw-runs/
test-results/
test_reports/
tools/
metatron-evidence-package-*/
metatron_temp/
zeek_logs/

# Android / Gradle wrapper downloads (do not commit)
unified_agent/ui/android/gradle-*/
unified_agent/ui/android/**/build/

# Downloaded binaries
backend/docker_cli

# Evidence directory is mostly runtime data; keep only Presence UI assets
evidence/**
!evidence/Presence UI/**
!evidence/Presence UI
